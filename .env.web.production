APP_NAME=DicomVision Server
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]
WEB_SAMPLE_DICOM_PATH=/opt/render/project/src/sample-data
WEB_UPLOAD_DICOM_ROOT=/tmp/dicomvision-web-uploads
WEB_UPLOAD_MAX_FILES=20000
WEB_UPLOAD_MAX_BYTES=2147483648
WEB_UPLOAD_MAX_ARCHIVE_ENTRIES=20000
WEB_UPLOAD_MAX_ARCHIVE_UNCOMPRESSED_BYTES=4294967296
WEB_UPLOAD_MAX_ARCHIVE_COMPRESSION_RATIO=200
