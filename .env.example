# 3D frame transport is fixed when the server starts: webp or webrtc.
DICOMVISION_3D_TRANSPORT=webrtc

# WebRTC quality/latency tuning. VP8 is the most portable aiortc path.
DICOMVISION_WEBRTC_VIDEO_CODEC=vp8
DICOMVISION_WEBRTC_VIDEO_BITRATE_BPS=4000000
DICOMVISION_WEBRTC_VIDEO_FPS=30
DICOMVISION_WEBRTC_INITIAL_BURST_FRAMES=2

# Lossless settled-frame encoder. "auto" benchmarks methods 0/1/2 once on a
# small sample of the first real 3D frame, then caches the fastest balanced choice.
# Set 0-6 to force a Pillow WebP method for repeatable deployment tuning.
DICOMVISION_3D_FINAL_WEBP_METHOD=auto

# Limits for ZIP, 7z, and RAR DICOM imports. Archives are extracted only into
# temporary upload sessions after path, size, and compression-ratio checks.
WEB_UPLOAD_MAX_ARCHIVE_ENTRIES=20000
WEB_UPLOAD_MAX_ARCHIVE_UNCOMPRESSED_BYTES=4294967296
WEB_UPLOAD_MAX_ARCHIVE_COMPRESSION_RATIO=200

# Public deployments should provide STUN/TURN as a JSON array.
# DICOMVISION_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.example.com:3478"}]
